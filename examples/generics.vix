import "std/io.vix"
struct Box:[T]
{
	value: T
}

fn id:[T](value: T): T
{
	return value
}
fn add:[T](a: T, b: T): T
{
    return a + b
}
type Flag:[T] = On | Off

fn main(): i32
{
	let b = Box:[i32]{ value: 10 }
	let x = id:[i32](b.value)
    let y = add:[i32](4,6)
    let z = add:[f64](2.5, 3.5)
    printf("b = %d\n", b.value);
    printf("x = %d\n", x);
	printf("y = %d\n", y);
	printf("z = %f\n", z)
    match x
    {
        10 ->
        {
            printf("OK\n")
        }
        _ ->
        {
            printf("FAIL\n")
            return 1
        }
    }
	let state = On
	match state
	{
		On ->
		{
			printf("OK\n")
		}
		Off ->
		{
			printf("FAIL\n")
			return 1
		}
	}
	return 0
}