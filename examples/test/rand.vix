extern "C"
{
    fn time() -> i64
}
global seed = time
fn rand(mini:i32,max:i32) ->i32
{
    seed = (seed * 9301 + 49297) % 233280
    if (seed < 0) {
        seed =  -  seed
    }
    return  mini + (seed % (max -  mini + 1))
}
fn main() ->  i32 {
    let n = 0
    for (i in  0 .. 10) {
        n =  rand(1, 100)
        print(n)
    }
}