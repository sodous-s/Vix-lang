type Result:[T, E] = Ok(T) | Err(E)

fn main(): i32
{
    let ok = Ok(42) : Result[i32, string]
    let bad = Err("division by zero") : Result[i32, string]

    match ok
    {
        Ok(v) -> print(v)
        Err(e) -> print(e)
    }

    match bad
    {
        Ok(v) -> print(v)
        Err(e) -> print(e)
    }

    return 0
}
