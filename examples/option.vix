fn first_or_none(list: [string]): ?string
{
    if (list.length > 0)
    {
        return Some(list[0])
    }
    return None
}

fn main(): i32
{
    let names = ["i32", "f64"]
    let empty = []

    let a = first_or_none(names)
    let b = first_or_none(empty)

    match a
    {
        Some(v) -> print(v)
        None -> print("names is empty")
    }

    match b
    {
        Some(v) -> print(v)
        None -> print("empty is empty")
    }

    return 0
}
