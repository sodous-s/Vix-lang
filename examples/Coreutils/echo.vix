import "std/strings.vix"
extern "C"
{
    fn printf(format:ptr,...): i32
    fn getenv(name: ptr) -> ptr
}
fn main(argc:i32,argv:ptr): i32
{
    let arg = 0
    for(i in 1 .. argc - 1)
    {
        if(strcmp(argv[i], "-n") == 0)
        {
            arg = 1
            continue
        }
        if(arg == 0)
        {
            printf("%s ", argv[i])
        }
        elif(arg == 1)
        {
            printf("%s ", argv[i])
        }
    }
    if(arg == 0)
    {
        printf("\n")
    }
    return 0
}