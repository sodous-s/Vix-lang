struct SymbolTable:[T]
{
    scopes: [ [ (string, T) ] ]
}
fn new_table:[T](): SymbolTable:[T]
{
    SymbolTable:[T]{ scopes: [ [] ] }
}
fn declare:[T](table: SymbolTable:[T], name: string, val: T)
{
    let idx = table.scopes.length - 1
    table.scopes[idx].push((name, val))
}
fn lookup:[T](table: SymbolTable:[T], name: string): ?T
{
    for (i in table.scopes.length-1 .. 0)
	{
        for (pair in table.scopes[i])
        {
            if (pair.0 == name)
			{
                return Some(pair.1)
            }
        }
    }
    return None
}
fn map:[T, U](list: [T], f: fn(T): U): [U]
{
    let out = []
    for (item in list)
	{
        out.push(f(item))
    }
    return out
}
type Result:[T, E] = Ok(T) | Err(E)
struct Type { name: string }
struct Expr { kind: string }

fn main(): i32 
{
    let tab = new_table:[Type]()
    declare:[Type](tab, "i32", Type{ name: "i32" })
    let t = lookup:[Type](tab, "i32")
    match t
	{
        Some(v) -> print(v.name)
        None -> print("not found")
    }
    let nums = [1, 2, 3]
    let doubled = map:[i32, i32](nums, fn(x: i32): i32 { x * 2 })
    print(doubled[0])  // 2
    let ok = Ok(42) : Result[i32, string]
    match ok
	{
        Ok(v) -> print(v)
        Err(e) -> print(e)
    }
    return 0
}